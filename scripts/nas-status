#!/usr/bin/env bash
set -euo pipefail

SCRIPT_PATH="${BASH_SOURCE[0]}"
while [[ -L "$SCRIPT_PATH" ]]; do
  SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$SCRIPT_PATH")" && pwd)"
  SCRIPT_PATH="$(readlink "$SCRIPT_PATH")"
  [[ "$SCRIPT_PATH" != /* ]] && SCRIPT_PATH="${SCRIPT_DIR}/${SCRIPT_PATH}"
done
SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$SCRIPT_PATH")" && pwd)"

# shellcheck source=scripts/lib/common.sh
source "${SCRIPT_DIR}/lib/common.sh"

main() {
  local remote_reachable="0" mount_active="0" primary_state secondary_state
  local usb_root="" sync_timestamp="" sync_age=""

  load_config
  require_command rclone

  REMOTE="$(detect_remote)"

  print_effective_config
  printf '\n'

  if remote_root_reachable "$REMOTE"; then
    remote_reachable="1"
    printf 'Remote     : reachable\n'
  else
    printf 'Remote     : unreachable\n'
  fi

  if is_mounted "$(local_mount_path)"; then
    mount_active="1"
    printf 'Mount      : active\n'
  else
    printf 'Mount      : inactive\n'
  fi

  if [[ -f "$PID_FILE" ]]; then
    local pid
    pid="$(read_pid)"
    if pid_is_alive "$pid"; then
      printf 'PID        : %s (running)\n' "$pid"
    else
      printf 'PID        : %s (stale)\n' "$pid"
    fi
  else
    printf 'PID        : none\n'
  fi

  primary_state="$(availability_load_value PRIMARY_STATE || printf 'unknown')"
  secondary_state="$(availability_load_value USB_STATE || printf 'unknown')"

  printf 'Primary    : %s\n' "$primary_state"
  printf 'Secondary  : %s\n' "$secondary_state"
  printf 'Source     : %s\n' "${SOURCE_POLICY}"

  if usb_root="$(detect_usb_root_macos 2>/dev/null)"; then
    printf 'USB root    : %s\n' "$usb_root"
    if usb_primary_sync_complete "$usb_root"; then
      sync_timestamp="$(usb_primary_sync_timestamp "$usb_root" || true)"
      sync_age="$(usb_primary_sync_age_hours "$usb_root" || true)"
      printf 'USB sync    : complete (%s, %sh old)\n' "${sync_timestamp:-unknown}" "${sync_age:-unknown}"
    else
      printf 'USB sync    : no completed primary sync manifest\n'
    fi
  fi

  printf '\nNext action : '
  if [[ "$remote_reachable" == "1" && "$mount_active" == "0" ]]; then
    printf 'run nas-mount to use the mobile primary workspace\n'
  elif [[ "$remote_reachable" == "1" && "$secondary_state" == "available" ]]; then
    printf 'run nas-mobile-usb-sync push-primary all to refresh the USB secondary from the primary\n'
  elif [[ "$remote_reachable" == "0" && "$secondary_state" == "available" ]]; then
    if [[ -n "$usb_root" ]] && usb_primary_sync_complete "$usb_root"; then
      printf 'run nas-usb-attach to use the USB continuity copy; recover to primary only with nas-mobile-usb-sync recover-primary ... --yes\n'
    else
      printf 'do not trust the USB as source yet; wait for the primary or refresh the USB from primary before relying on it\n'
    fi
  elif [[ "$remote_reachable" == "0" ]]; then
    printf 'restore connectivity to the mobile primary or attach a known-good USB secondary\n'
  else
    printf 'system is usable; run nas-doctor if you want a deeper check\n'
  fi
}

main "$@"
