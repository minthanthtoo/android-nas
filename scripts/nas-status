#!/usr/bin/env bash
set -euo pipefail

SCRIPT_PATH="${BASH_SOURCE[0]}"
while [[ -L "$SCRIPT_PATH" ]]; do
  SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$SCRIPT_PATH")" && pwd)"
  SCRIPT_PATH="$(readlink "$SCRIPT_PATH")"
  [[ "$SCRIPT_PATH" != /* ]] && SCRIPT_PATH="${SCRIPT_DIR}/${SCRIPT_PATH}"
done
SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$SCRIPT_PATH")" && pwd)"

# shellcheck source=scripts/lib/common.sh
source "${SCRIPT_DIR}/lib/common.sh"

main() {
  load_config
  require_command rclone

  REMOTE="$(detect_remote)"

  print_effective_config
  printf '\n'

  if remote_root_reachable "$REMOTE"; then
    printf 'Remote     : reachable\n'
  else
    printf 'Remote     : unreachable\n'
  fi

  if is_mounted "$(local_mount_path)"; then
    printf 'Mount      : active\n'
  else
    printf 'Mount      : inactive\n'
  fi

  if [[ -f "$PID_FILE" ]]; then
    local pid
    pid="$(read_pid)"
    if pid_is_alive "$pid"; then
      printf 'PID        : %s (running)\n' "$pid"
    else
      printf 'PID        : %s (stale)\n' "$pid"
    fi
  else
    printf 'PID        : none\n'
  fi
}

main "$@"
